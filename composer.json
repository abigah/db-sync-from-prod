{
    "name": "abigah/db-sync-from-prod",
    "description": "Artisan command to sync the local database from a production database over an SSH tunnel.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Sheldon Kotyk",
            "email": "sheldon.kotyk@p2c.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^10.0 || ^11.0 || ^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Abigah\\DbSyncFromProd\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Abigah\\DbSyncFromProd\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Abigah\\DbSyncFromProd\\DbSyncFromProdServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
